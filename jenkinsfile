pipeline {

    agent {
        docker {
            image 'python:3.10'
            args '-u root'
        }
    }
    options{
        disableConcurrentBuilds()
    }

    triggers {
        cron('H/5 * * * *')
    }

    stages {

        stage('Setup Environment') {
            steps {
                sh '''
                echo "Checking virtual environment..."

                if [ ! -d "venv" ]; then
                    echo "Creating virtual environment..."
                    python -m venv venv

                    echo "Installing dependencies..."
                    ./venv/bin/pip install --upgrade pip
                    ./venv/bin/pip install -r requirements.txt
                else
                    echo "Using cached virtual environment"
                fi
                '''
            }
        }

        stage('Check Pending Posts') {
            steps {
                sh '''
                curl http://10.11.144.100:8000/api/check_pending
                '''
            }
        }

        stage('Create Dataset') {
            steps {
                script {

                    def output = sh(
                        script: '''
                        ./venv/bin/python -m backend.app.services.dataset_creation
                        ''',
                        returnStdout: true
                    ).trim()

                    echo output

                    def matcher = output =~ /ROWS_ADDED=(\\d+)/

                    if (matcher) {
                        env.ROWS = matcher[0][1]
                    } else {
                        env.ROWS = "0"
                    }

                    echo "Rows Added: ${env.ROWS}"
                }
            }
        }

        stage('Retrain Model') {

            when {
                expression {
                    return env.ROWS.toInteger() > 10
                }
            }

            steps {
                sh '''
                ./venv/bin/python backend/app/ml_model/train_model.py
                '''
            }
        }

    }
}