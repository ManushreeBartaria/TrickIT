pipeline {
    agent any

    triggers {
        cron('H/1 * * * *')
    }

    stages {

        stage('Check Pending Posts') {
            steps {
                sh '''
                curl http://10.161.95.66:8000/api/check_pending
                '''
            }
        }

        stage('Create Dataset') {
            steps {
                script {
                    def output = sh(
                        script: '''
                        cd backend
                        source venv/bin/activate || true
                        python -m app.services.dataset_creation
                        ''',
                        returnStdout: true
                    ).trim()

                    echo output

                    def matcher = output =~ /ROWS_ADDED=(\\d+)/
                    if (matcher) {
                        env.ROWS = matcher[0][1]
                    } else {
                        env.ROWS = "0"
                    }

                    echo "Rows Added: ${env.ROWS}"
                }
            }
        }

        stage('Retrain Model') {
            when {
                expression {
                    return env.ROWS.toInteger() > 10
                }
            }

            steps {
                sh '''
                cd backend
                source venv/bin/activate || true
                python app/ml_model/train_model.py
                '''
            }
        }

    }
}