pipeline {

    agent any

    options{
        disableConcurrentBuilds()
    }

    triggers {
        cron('H/5 * * * *')
    }

    stages {

        stage('Check Pending Posts') {
            steps {
                
                    sh '''
                    curl http://10.161.176.91:8000/api/check_pending
                    '''
            }
        }

        stage('Trigger ML Pipeline') {
            steps {
                sh '''
                curl -X POST http://10.161.176.91:8000/api/retrain_pipeline
                '''
            }
        }
    }
}